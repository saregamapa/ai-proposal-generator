# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
FRONTEND_URL=https://aiproposal.io
NEXT_PUBLIC_API_URL=https://aiproposal.io/api

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/proposal_db?schema=public
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=proposal_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:yourredispassword@localhost:6379
REDIS_PASSWORD=yourredispassword

# ─── JWT (use strong random 64-char strings) ──────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_64_CHAR_RANDOM_STRING

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://aiproposal.io/api/auth/google/callback

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o

# ─── Stripe ───────────────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_AGENCY_PRICE_ID=price_...

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_BUCKET=ai-proposal-generator-prod

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@aiproposal.io

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_QUERIES=false
